# Copy to .env and fill in values

PORT=5000
NODE_ENV=development

# PostgreSQL – use connection string format
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/gigshield

# Redis – RedisLabs or local
REDIS_URL=redis://:PASSWORD@host:port

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ML Service (must be running on localhost before starting backend)
ML_BASE_URL=http://localhost:8000

# Razorpay (simulated in dev)
RAZORPAY_KEY_ID=rzp_test_simulated
RAZORPAY_KEY_SECRET=simulated_secret

# Cron (default: every 15 minutes)
TRIGGER_CRON_INTERVAL=*/15 * * * *

# Frontend CORS origin
FRONTEND_URL=http://localhost:3000
