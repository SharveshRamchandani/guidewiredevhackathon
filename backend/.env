# ───────────────────────────────────────
# GigShield Backend — Environment Config
# Copy to .env and fill in real values
# ───────────────────────────────────────

# App
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:8080

# Database
DATABASE_URL=postgres://postgres:Niggapls@localhost:5432/gigshield

# Redis
REDIS_URL=rediss://:40hQlbfDtS3u1iit4pbOLEDplNHGOt2t@redis-14806.crce283.ap-south-1-2.ec2.cloud.redislabs.com:14806
REDIS_TLS=true

ML_BASE_URL=http://localhost:8000

# JWT
JWT_SECRET=gigshield_secret_2026_minimum_32chars_here
JWT_EXPIRES_IN=24h
JWT_ADMIN_EXPIRES_IN=8h
JWT_REGISTRATION_EXPIRES_IN=30m

# OTP
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# Admin Setup Token
ADMIN_SETUP_TOKEN_EXPIRY_HOURS=24

# Super Admin — Google-First Setup
# Set this to the Google account email that will be the Super Admin.
# Run:  npm run seed:super-admin
# Then: go to /admin/login → Sign in with Google using this email.
SUPER_ADMIN_EMAIL=srikrishnan.cb23@bitsathy.ac.in
SUPER_ADMIN_NAME=GigShield Platform Owner
# SUPER_ADMIN_PASSWORD is not used — super admin authenticates via Google OAuth only.

# Feature Flags
FEATURE_SMS_ENABLED=false
FEATURE_TOTP_ENABLED=false
FEATURE_EMAIL_ENABLED=false

# Cron
TRIGGER_CRON_INTERVAL=*/15 * * * *

# Razorpay (simulated in dev)
RAZORPAY_KEY_ID=rzp_test_simulated
RAZORPAY_KEY_SECRET=simulated_secret

# Session secret (for any legacy OAuth / session only)
SESSION_SECRET=gigshield_session_secret_change_in_prod

# Backend URL
BACKEND_URL=http://localhost:5000

# Google OAuth (Admin Login)
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=397269296188-d091isc7mcu1f6i399rqkmilv59046co.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
